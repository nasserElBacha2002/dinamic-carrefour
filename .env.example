# ──────────────────────────────────────────────────────────
# Configuración del sistema (valores por defecto)
# Copiar a .env y ajustar según necesidad
# ──────────────────────────────────────────────────────────

# Detección YOLO — Confianza mínima (0-1)
YOLO_CONFIDENCE=0.25

# Identificación SKU — Umbral de similitud (0-1)
SKU_THRESHOLD=0.75

# Modelo CLIP a usar (ViT-B/32 es el más rápido)
CLIP_MODEL=ViT-B/32

# FPS para extracción de frames
FPS_EXTRACCION=1.0
